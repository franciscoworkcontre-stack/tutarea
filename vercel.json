{
  "framework": "nextjs",
  "buildCommand": "pnpm build",
  "installCommand": "pnpm install",
  "devCommand": "pnpm dev",
  "crons": [
    {
      "path": "/api/telegram/daily-digest",
      "schedule": "0 13 * * 1-5"
    },
    {
      "path": "/api/telegram/due-alerts",
      "schedule": "0 9 * * *"
    }
  ]
}
